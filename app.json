{
  "expo": {
    "name": "SANKALP AI",
    "slug": "sankalp-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sankalpai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sankalpai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SANKALP AI needs your location to show nearby civic issues, police stations, and to share your location during SOS emergencies.",
        "NSLocationAlwaysUsageDescription": "SANKALP AI uses your location in the background during active SOS emergencies to keep police updated.",
        "NSMicrophoneUsageDescription": "SANKALP AI records audio during Women Safety SOS activations as evidence.",
        "NSSpeechRecognitionUsageDescription": "SANKALP AI uses speech to detect voice-activated SOS commands."
      }
    },
    "android": {
      "package": "com.sankalpai",
      "adaptiveIcon": {
        "backgroundColor": "#0A0F1C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "sankalpai://"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SANKALP AI needs your location to show nearby civic issues, police stations, and to share your GPS during SOS emergencies.",
          "locationWhenInUsePermission": "SANKALP AI needs your location to show nearby civic issues and police stations.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF9933",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "SANKALP AI records audio during Women Safety SOS activations as evidence."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "sankalpai://"
      }
    }
  }
}
